#include <iostream>
using namespace std;

struct Nodo{
    int Clave;
    Nodo *Izquierda;
    Nodo *Derecha;
};

class ABB{
public:
    Nodo *Raiz;

    ABB(){
        Raiz = NULL;
    }

    Nodo* BusquedaIngenua(int x, Nodo *nodo);
};

Nodo* ABB::BusquedaIngenua(int x, Nodo *nodo)
{
    if(nodo == NULL)
        return NULL;

    if(nodo->Clave == x)
        return nodo;

    Nodo *aux = BusquedaIngenua(x, nodo->Izquierda);

    if(aux != NULL)
        return aux;

    return BusquedaIngenua(x, nodo->Derecha);
}

int main()
{
    ABB arbol;

    arbol.Raiz = new Nodo{50,NULL,NULL};
    arbol.Raiz->Izquierda = new Nodo{30,NULL,NULL};
    arbol.Raiz->Derecha = new Nodo{70,NULL,NULL};

    Nodo *p = arbol.BusquedaIngenua(70, arbol.Raiz);

    if(p != NULL)
        cout << "Encontrado: " << p->Clave;
    else
        cout << "No encontrado";

    return 0;
}
