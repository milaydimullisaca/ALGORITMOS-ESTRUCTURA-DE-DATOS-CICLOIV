def raiz_rec(x, inf, sup, epsilon):
    m = (inf + sup) / 2.0
    
    if abs(m**2 - x) < epsilon:
        return m
    
    if m**2 < x:
        return raiz_rec(x, m, sup, epsilon)
    else:
        return raiz_rec(x, inf, m, epsilon)

x = 36
epsilon = 0.01

resultado = raiz_rec(x, 0, x, epsilon)

print(resultado, "es aproximadamente la raíz cuadrada de", x)
